{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Validate SAP Cloud ALM MCP",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": ["-m", "pytest", "-q"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONPATH": "src"
        }
      },
      "group": "test"
    },
    {
      "label": "Run SAP Cloud ALM MCP",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": ["-m", "sap_cloud_alm_mcp"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONPATH": "src"
        }
      },
      "isBackground": true,
      "group": "build"
    }
  ]
}
